{
  "name": "sales-support-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev-start.ts",
    "dev:next": "tsx scripts/dev-start.ts --no-clean",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev",
    "build": "next build",
    "start": "next start",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:prepare-users": "tsx scripts/fix-parijat-db.ts",
    "prepare:local": "tsx scripts/prepare-local.ts",
    "predev": "npm run db:generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^1.18.0",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.25",
    "node-html-parser": "^7.0.1",
    "openai": "^5.3.0",
    "pino": "^10.3.1",
    "playwright": "^1.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^4.5.1",
    "zod": "^3.25.67"
  }
}
