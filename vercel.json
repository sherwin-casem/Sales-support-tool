{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm ci",
  "regions": ["fra1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-leads",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/send-campaigns",
      "schedule": "*/5 * * * *"
    }
  ]
}
