# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://sales:sales@localhost:5432/sales_intelligence?schema=public"
DIRECT_URL="postgresql://sales:sales@localhost:5432/sales_intelligence?schema=public"

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY="sk-your-key-here"
OPENAI_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Production: set a long random secret and send Authorization: Bearer <secret>:<userId>
# Development: leave unset and use ALLOW_DEV_UUID_AUTH=true with UUID bearer tokens
API_AUTH_SECRET=""
ALLOW_DEV_UUID_AUTH="true"
ALLOW_PUBLIC_SIGNUP="true"
AUTH_SECRET="change-me-to-a-long-random-secret"
CRON_SECRET="change-me-for-cron-routes"
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=60
API_SEARCH_RATE_LIMIT_MAX=5
API_REGISTER_RATE_LIMIT_MAX=5
API_MAX_CONCURRENT_SEARCHES=2
API_MAX_JSON_BODY_BYTES=16384

# Client-side dev user (legacy bearer auth for external API clients only)
NEXT_PUBLIC_DEV_USER_ID="00000000-0000-4000-8000-000000000001"

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="info"

# ---------------------------------------------------------------------------
# Crawler (Playwright)
# ---------------------------------------------------------------------------
CRAWLER_MAX_CONTEXTS=3
CRAWLER_GLOBAL_CONCURRENCY=3
CRAWLER_INTER_PAGE_DELAY_MS=0
CRAWLER_DOMAIN_DELAY_MS=0
CRAWLER_NAVIGATION_TIMEOUT_MS=30000
CRAWLER_PAGE_ACTION_TIMEOUT_MS=10000
CRAWLER_COMPANY_TIMEOUT_MS=120000
CRAWLER_POOL_ACQUIRE_TIMEOUT_MS=15000
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_PAGE_MAX_ATTEMPTS=3
CRAWLER_USER_AGENT="SalesIntelligenceBot/1.0 (+https://example.com/bot)"

# ---------------------------------------------------------------------------
# Outreach & campaigns
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
OUTREACH_FROM_EMAIL="sales@parijat.com"
OUTREACH_FROM_NAME="Parijat Sales"
OUTREACH_SEND_RATE_PER_MINUTE=50
OUTREACH_EMAIL_RATE_PER_MINUTE=50
OUTREACH_WHATSAPP_RATE_PER_MINUTE=20
OUTREACH_LINKEDIN_RATE_PER_MINUTE=10

# WhatsApp (Meta Cloud API default)
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_DEFAULT_TEMPLATE=""
WHATSAPP_TEMPLATE_LANGUAGE="en_US"

# LinkedIn (Unipile third-party)
LINKEDIN_PROVIDER=unipile
UNIPILE_API_KEY=""
UNIPILE_ACCOUNT_ID=""
UNIPILE_WEBHOOK_SECRET=""

REFRESH_BATCH_SIZE=10
REFRESH_CONCURRENCY=2

# ---------------------------------------------------------------------------
# Search pipeline (OpenAI stages)
# ---------------------------------------------------------------------------
SEARCH_ENRICHMENT_CONCURRENCY=3
DISCOVERY_UNLIMITED_MAX_ROUNDS=5
SEARCH_MIN_PROFILE_COMPLETENESS=0.35

# Stale job cleanup — auto-fail orphaned searches (e.g. after dev server restart)
SEARCH_JOB_PENDING_STALE_MS=300000
SEARCH_JOB_ACTIVE_STALE_MS=1200000
